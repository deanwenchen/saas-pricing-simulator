---
import Layout from '../layouts/Layout.astro';
---
<Layout title="SaaS Pricing & LTV/CAC Metric Calculator" description="Calculate SaaS LTV, CAC ratio, break-even point, and unit economics.">
  <style>input[type="range"]::-webkit-slider-runnable-track{height:8px;border-radius:9999px;background:linear-gradient(to right,#c7d2fe,#6366f1);}input[type="range"]::-moz-range-track{height:8px;border-radius:9999px;background:linear-gradient(to right,#c7d2fe,#6366f1);}</style>
  <section class="mb-8"><p class="text-gray-600 leading-relaxed">Calculate <strong>SaaS LTV</strong>, <strong>CAC</strong>, <strong>LTV/CAC ratio</strong>, and <strong>break-even point</strong>. Essential for indie hackers.</p></section>
  <section id="calculator">
    <div class="grid sm:grid-cols-2 gap-4 mb-6">
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200"><label for="price" class="block text-sm font-semibold text-gray-700 mb-2">Monthly Price ($)</label><input type="number" id="price" min="1" value="29" class="w-full px-3 py-2.5 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:outline-none"/></div>
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200"><label for="churn" class="block text-sm font-semibold text-gray-700 mb-2">Monthly Churn (%)</label><input type="number" id="churn" min="0.1" max="50" step="0.1" value="5" class="w-full px-3 py-2.5 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:outline-none"/></div>
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200"><label for="cac" class="block text-sm font-semibold text-gray-700 mb-2">CAC ($)</label><input type="number" id="cac" min="1" value="150" class="w-full px-3 py-2.5 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:outline-none"/></div>
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200"><label for="cogs" class="block text-sm font-semibold text-gray-700 mb-2">COGS (%)</label><input type="number" id="cogs" min="0" max="90" value="20" class="w-full px-3 py-2.5 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:outline-none"/></div>
    </div>
    <button id="calcBtn" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-lg mb-6">Calculate Metrics</button>
    <div id="results" class="hidden">
      <div class="grid sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-xl p-5 text-white text-center"><p class="text-sm opacity-80 mb-1">LTV</p><p class="text-4xl font-bold" id="resLtv">$580</p></div>
        <div class="bg-gradient-to-br from-violet-500 to-violet-600 rounded-xl p-5 text-white text-center"><p class="text-sm opacity-80 mb-1">LTV/CAC</p><p class="text-4xl font-bold" id="resRatio">3.9x</p></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6 text-center text-sm"><div class="bg-gray-50 rounded-lg p-3"><p class="text-xs text-gray-500 mb-1">Lifetime</p><p class="font-bold text-gray-800" id="resLifetime">20 mo</p></div><div class="bg-gray-50 rounded-lg p-3"><p class="text-xs text-gray-500 mb-1">Break-even</p><p class="font-bold text-indigo-700" id="resBreakeven">5 mo</p></div><div class="bg-gray-50 rounded-lg p-3"><p class="text-xs text-gray-500 mb-1">Margin</p><p class="font-bold text-green-600" id="resMargin">80%</p></div><div class="bg-gray-50 rounded-lg p-3"><p class="text-xs text-gray-500 mb-1">Payback</p><p class="font-bold text-indigo-700" id="resPayback">3.2 mo</p></div></div>
      <div id="healthBadge" class="rounded-lg p-4 mb-6 text-center"><p class="text-sm font-semibold" id="healthText">Healthy</p><p class="text-xs mt-1" id="healthDetail"></p></div>
    </div>
  </section>
  <section class="mt-10 mb-8"><h2 class="text-2xl font-bold text-gray-800 mb-4">SaaS Metrics</h2><div class="grid sm:grid-cols-2 gap-4"><div class="bg-indigo-50 rounded-lg p-4 border border-indigo-100"><h3 class="font-semibold text-indigo-800 mb-2">LTV</h3><p class="text-sm text-indigo-700">Total revenue per customer. Formula: ARPA / Churn.</p></div><div class="bg-violet-50 rounded-lg p-4 border border-violet-100"><h3 class="font-semibold text-violet-800 mb-2">CAC</h3><p class="text-sm text-violet-700">Cost to acquire one customer.</p></div><div class="bg-green-50 rounded-lg p-4 border border-green-100"><h3 class="font-semibold text-green-800 mb-2">LTV/CAC</h3><p class="text-sm text-green-700">Target 3x+. Below 1x means losing money.</p></div><div class="bg-amber-50 rounded-lg p-4 border border-amber-100"><h3 class="font-semibold text-amber-800 mb-2">Break-even</h3><p class="text-sm text-amber-700">Months until customer pays back CAC.</p></div></div></section>
  <section id="faq" class="mb-8"><h2 class="text-2xl font-bold text-gray-800 mb-6">FAQ</h2><div class="space-y-4"><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">Good LTV/CAC?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p><strong>3:1+</strong> is healthy. Below 1:1 means losing money.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">How to calculate LTV?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p>LTV = (ARPA x Gross Margin) / Churn Rate.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">Good churn rate?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p>Under 5% monthly for SMB. Enterprise under 2%.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">Reduce churn?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p>Better onboarding, value delivery, proactive support.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">Break-even?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p>Months until revenue exceeds CAC. CAC / (ARPA x Margin).</p></div></details></div></section>
  <script type="application/ld+json" is:inline>{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Good LTV/CAC?","acceptedAnswer":{"@type":"Answer","text":"3:1+ healthy. Below 1:1 losing money."}},{"@type":"Question","name":"How to calculate LTV?","acceptedAnswer":{"@type":"Answer","text":"(ARPA x Margin) / Churn."}},{"@type":"Question","name":"Good churn?","acceptedAnswer":{"@type":"Answer","text":"Under 5% monthly SMB. Under 2% enterprise."}},{"@type":"Question","name":"Reduce churn?","acceptedAnswer":{"@type":"Answer","text":"Better onboarding, value, support."}},{"@type":"Question","name":"Break-even?","acceptedAnswer":{"@type":"Answer","text":"Months until revenue > CAC."}}]}</script>
  <script is:inline define:vars={{}}>
    (function(){document.getElementById("calcBtn").addEventListener("click",function(){var p=parseFloat(document.getElementById("price").value)||29,ch=parseFloat(document.getElementById("churn").value)/100||0.05,c=parseFloat(document.getElementById("cac").value)||150,co=parseFloat(document.getElementById("cogs").value)/100||0.2,m=1-co,arpa=p*m,l=arpa/ch,r=l/c,lt=1/ch,pb=c/arpa,be=Math.ceil(pb);document.getElementById("resLtv").textContent="$"+Math.round(l).toLocaleString();document.getElementById("resRatio").textContent=r.toFixed(1)+"x";document.getElementById("resLifetime").textContent=Math.round(lt)+" mo";document.getElementById("resBreakeven").textContent=be+" mo";document.getElementById("resMargin").textContent=Math.round(m*100)+"%";document.getElementById("resPayback").textContent=pb.toFixed(1)+" mo";var b=document.getElementById("healthBadge"),ht=document.getElementById("healthText"),hd=document.getElementById("healthDetail");if(r>=3){b.className="bg-green-50 rounded-lg p-4 mb-6 text-center border border-green-200";ht.className="text-sm font-semibold text-green-800";hd.className="text-xs text-green-600 mt-1";ht.textContent="Healthy Unit Economics";hd.textContent="LTV/CAC >= 3x. Sustainable.";}else if(r>=1){b.className="bg-yellow-50 rounded-lg p-4 mb-6 text-center border border-yellow-200";ht.className="text-sm font-semibold text-yellow-800";hd.className="text-xs text-yellow-600 mt-1";ht.textContent="Needs Improvement";hd.textContent="LTV/CAC 1-3x. Reduce CAC or raise price.";}else{b.className="bg-red-50 rounded-lg p-4 mb-6 text-center border border-red-200";ht.className="text-sm font-semibold text-red-800";hd.className="text-xs text-red-600 mt-1";ht.textContent="Unhealthy";hd.textContent="LTV/CAC < 1x. Losing money per customer.";}document.getElementById("results").classList.remove("hidden");});document.getElementById("calcBtn").click();})();
  </script>
</Layout>
